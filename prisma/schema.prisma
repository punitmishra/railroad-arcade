// Prisma Schema for Railroad Arcade
// Using Neon Postgres with serverless driver

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================
// NextAuth.js Required Models
// ============================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================
// User Model (Extended for Railroad Arcade)
// ============================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?   // For credentials auth

  // Railroad Arcade specific
  tokenBalance    Int       @default(0)
  totalTokensUsed Int       @default(0)
  totalSessions   Int       @default(0)
  unlockedModules String[]  @default(["trains", "scenery"])

  // Relations
  accounts     Account[]
  sessions     Session[]
  playSessions PlaySession[]
  transactions Transaction[]
  snapshots    Snapshot[]
  achievements Achievement[]
  liveQueues   LiveQueue[]
  gameSessions GameSession[]
  leaderboards Leaderboard[]
  recordings   Recording[]
  checkpoints  GameCheckpoint[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================
// Railroad Arcade Models
// ============================================

model PlaySession {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  startTime   DateTime @default(now())
  endTime     DateTime?
  duration    Int?     // Duration in seconds
  tokensSpent Int      @default(0)
  status      PlaySessionStatus @default(ACTIVE)

  // Session stats
  totalDistance    Float    @default(0) // km traveled
  trainsOperated   String[] @default([])
  modulesUsed      String[] @default([])

  // Relations
  events       SessionEvent[]
  tokenActions TokenAction[]
  gameSession  GameSession?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum PlaySessionStatus {
  ACTIVE
  COMPLETED
  INTERRUPTED
  EMERGENCY_STOPPED
}

model SessionEvent {
  id          String      @id @default(cuid())
  sessionId   String
  session     PlaySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  type        SessionEventType
  description String
  trainId     String?
  level       Int?
  metadata    Json?
  timestamp   DateTime    @default(now())
}

enum SessionEventType {
  TRAIN_START
  TRAIN_STOP
  JUNCTION_SWITCH
  CROSSING_ACTIVATED
  SNAPSHOT
  ACHIEVEMENT
  EMERGENCY
  MODULE_UNLOCK
  TOKEN_SPEND
}

model Transaction {
  id       String            @id @default(cuid())
  userId   String
  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  type     TransactionType
  amount   Int               // Token amount (positive for purchase, negative for spend)
  price    Float?            // USD amount if purchase
  currency String?           // usd, btc, eth
  provider PaymentProvider?
  status   TransactionStatus @default(PENDING)

  // Payment provider reference
  externalId String? // Stripe payment intent, PayPal order ID, Coinbase charge ID
  metadata   Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum TransactionType {
  PURCHASE
  SPEND
  REFUND
  BONUS
}

enum PaymentProvider {
  STRIPE
  PAYPAL
  COINBASE
  SYSTEM // For bonuses, refunds, etc.
}

enum TransactionStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
}

model Snapshot {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionId String?

  url       String
  thumbnail String?
  camera    String
  trainId   String?
  trainName String?
  level     Int

  liked       Boolean  @default(false)
  tags        String[] @default([])
  description String?

  createdAt DateTime @default(now())
}

model Achievement {
  id       String          @id @default(cuid())
  userId   String
  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  type     AchievementType
  earnedAt DateTime        @default(now())

  @@unique([userId, type])
}

enum AchievementType {
  FIRST_RUN
  SPEED_DEMON
  NIGHT_OWL
  COLLECTOR
  MARATHON
  EXPLORER
  PHOTOGRAPHER
  CONDUCTOR
  MASTER_ENGINEER
  VETERAN
  // Tournament achievements
  TOURNAMENT_CHAMPION
  TOURNAMENT_SILVER
  TOURNAMENT_BRONZE
}

// ============================================
// Live Queue System (for fair hardware access)
// ============================================

model LiveQueue {
  id             String      @id @default(cuid())
  userId         String
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  status         QueueStatus @default(WAITING)
  joinedAt       DateTime    @default(now())
  controlStarted DateTime?
  controlEndsAt  DateTime?
  tokensPaid     Int
  position       Int?
  priority       Int         @default(0) // 0 = normal, 1+ = priority (higher skips ahead)

  @@index([status, priority, joinedAt])
}

enum QueueStatus {
  WAITING
  ACTIVE
  COMPLETED
  CANCELLED
  EXPIRED
}

// ============================================
// Token Actions (per-action billing)
// ============================================

model TokenAction {
  id          String      @id @default(cuid())
  sessionId   String
  session     PlaySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  actionType  ActionType
  tokenCost   Int
  timestamp   DateTime    @default(now())
  metadata    Json?
}

enum ActionType {
  TRAIN_START
  TRAIN_STOP
  JUNCTION_SWITCH
  CROSSING_TOGGLE
  SCENERY_CHANGE
  TIME_EXTEND
  CAMERA_SWITCH
}

// ============================================
// Game Sessions & Leaderboards
// ============================================

model GameSession {
  id            String       @id @default(cuid())
  userId        String
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  playSessionId String?      @unique
  playSession   PlaySession? @relation(fields: [playSessionId], references: [id])
  gameMode      GameMode
  startTime     DateTime     @default(now())
  endTime       DateTime?
  score         Int          @default(0)
  isLive        Boolean      @default(false)
  metadata      Json?

  @@index([gameMode, score])
}

enum GameMode {
  FREE_PLAY
  DELIVERY_MISSION
  SPEED_RUN
  SURVIVAL
  TIME_ATTACK
}

model Leaderboard {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  gameMode   GameMode
  score      Int
  isLive     Boolean
  achievedAt DateTime @default(now())

  @@unique([userId, gameMode, isLive])
  @@index([gameMode, isLive, score])
}

// ============================================
// Recording System
// ============================================

model Recording {
  id        String          @id @default(cuid())
  userId    String
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionId String?
  startTime DateTime
  endTime   DateTime?
  duration  Int?
  url       String?
  thumbnail String?
  camera    String
  status    RecordingStatus @default(RECORDING)

  createdAt DateTime @default(now())
}

enum RecordingStatus {
  RECORDING
  PROCESSING
  READY
  FAILED
}

// ============================================
// Queue Jobs (for tracking async operations)
// ============================================

model QueueJob {
  id        String      @id @default(cuid())
  type      String
  payload   Json
  status    JobStatus   @default(PENDING)
  attempts  Int         @default(0)
  error     String?
  result    Json?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

// ============================================
// Tournament System
// ============================================

model Tournament {
  id          String           @id @default(cuid())
  name        String
  description String?
  type        TournamentType
  status      TournamentStatus @default(SCHEDULED)
  gameMode    GameMode

  // Schedule
  registrationStart DateTime
  registrationEnd   DateTime
  startTime         DateTime
  endTime           DateTime

  // Rules
  maxParticipants  Int     @default(100)
  entryFee         Int     @default(0) // tokens
  minLevel         Int     @default(1)
  attemptsPerPlayer Int    @default(3)

  // Prizes
  prizePool Int      @default(0) // total tokens
  prizes    Json?    // Array of prize tiers

  // Relations
  entries TournamentEntry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, startTime])
}

enum TournamentType {
  DAILY
  WEEKLY
  SPECIAL
  CHAMPIONSHIP
}

enum TournamentStatus {
  SCHEDULED
  REGISTRATION
  ACTIVE
  COMPLETED
  CANCELLED
}

model TournamentEntry {
  id           String     @id @default(cuid())
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  userId       String
  score        Int        @default(0)
  attempts     Int        @default(0)
  bestTime     Int?       // Best completion time in seconds
  rank         Int?

  registeredAt  DateTime  @default(now())
  lastAttemptAt DateTime?

  @@unique([tournamentId, userId])
  @@index([tournamentId, score])
}

// ============================================
// Game Checkpoints (Save/Resume System)
// ============================================

model GameCheckpoint {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String   @default("Checkpoint")
  gameMode  GameMode
  isLive    Boolean  @default(false)

  // Game state
  score           Int      @default(0)
  timeRemaining   Int?     // Seconds remaining (for timed modes)
  timeElapsed     Int      @default(0) // Seconds played

  // Train positions and states
  trainStates     Json     // { trainId: { track, position, speed, direction } }

  // Track states
  junctionStates  Json     // { junctionId: { thrown: boolean } }
  crossingStates  Json     // { crossingId: { active: boolean } }

  // Game mode specific data
  objectives      Json?    // Completed objectives, targets, etc.
  metadata        Json?    // Any additional mode-specific state

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, gameMode])
}
