{
  "name": "Railroad Arcade",
  "short_name": "Railroad",
  "description": "Control a real 2-level model railroad with trains, buildings, and scenery. Interactive HO scale experience!",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "display_override": ["window-controls-overlay", "standalone"],
  "background_color": "#050508",
  "theme_color": "#050508",
  "orientation": "any",
  "id": "/",
  "icons": [
    {
      "src": "/icons/icon-72.png",
      "sizes": "72x72",
      "type": "image/png"
    },
    {
      "src": "/icons/icon-96.png",
      "sizes": "96x96",
      "type": "image/png"
    },
    {
      "src": "/icons/icon-128.png",
      "sizes": "128x128",
      "type": "image/png"
    },
    {
      "src": "/icons/icon-144.png",
      "sizes": "144x144",
      "type": "image/png"
    },
    {
      "src": "/icons/icon-152.png",
      "sizes": "152x152",
      "type": "image/png"
    },
    {
      "src": "/icons/icon-192.png",
      "sizes": "192x192",
      "type": "image/png"
    },
    {
      "src": "/icons/icon-384.png",
      "sizes": "384x384",
      "type": "image/png"
    },
    {
      "src": "/icons/icon-512.png",
      "sizes": "512x512",
      "type": "image/png"
    },
    {
      "src": "/icons/icon-maskable-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "/icons/icon-maskable-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "/icons/icon-192.svg",
      "sizes": "any",
      "type": "image/svg+xml"
    }
  ],
  "shortcuts": [
    {
      "name": "Start Playing",
      "short_name": "Play",
      "description": "Jump straight into controlling the railroad",
      "url": "/?play=true",
      "icons": [{ "src": "/icons/shortcut-play.png", "sizes": "96x96" }]
    },
    {
      "name": "Leaderboards",
      "short_name": "Scores",
      "description": "View high scores and rankings",
      "url": "/leaderboards",
      "icons": [{ "src": "/icons/shortcut-trophy.png", "sizes": "96x96" }]
    },
    {
      "name": "Get Tokens",
      "short_name": "Tokens",
      "description": "Purchase tokens to play",
      "url": "/?showTokenStore=true",
      "icons": [{ "src": "/icons/shortcut-tokens.png", "sizes": "96x96" }]
    }
  ],
  "screenshots": [
    {
      "src": "/screenshots/main-view.png",
      "sizes": "1280x720",
      "type": "image/png",
      "label": "Main railroad control view"
    },
    {
      "src": "/screenshots/trains-tab.png",
      "sizes": "1280x720",
      "type": "image/png",
      "label": "Train tracking and control"
    },
    {
      "src": "/screenshots/camera-grid.png",
      "sizes": "1280x720",
      "type": "image/png",
      "label": "Multi-camera grid view"
    }
  ],
  "categories": ["games", "entertainment", "education"],
  "prefer_related_applications": false,
  "related_applications": [],
  "launch_handler": {
    "client_mode": "navigate-existing"
  },
  "handle_links": "preferred",
  "edge_side_panel": {
    "preferred_width": 400
  }
}
