# Railroad Arcade Environment Variables

# ===========================================
# Raspberry Pi Control Server
# ===========================================
NEXT_PUBLIC_API_URL=http://localhost:5000

# ===========================================
# Database (Neon Postgres)
# ===========================================
# Get these from: https://console.neon.tech
DATABASE_URL="postgresql://user:password@host/database?sslmode=require"
DIRECT_URL="postgresql://user:password@host/database?sslmode=require"

# ===========================================
# Upstash Redis
# ===========================================
# Get these from: https://console.upstash.com
UPSTASH_REDIS_REST_URL="https://xxx.upstash.io"
UPSTASH_REDIS_REST_TOKEN="xxx"

# ===========================================
# Upstash QStash
# ===========================================
# Get these from: https://console.upstash.com/qstash
QSTASH_TOKEN="xxx"
QSTASH_CURRENT_SIGNING_KEY="xxx"
QSTASH_NEXT_SIGNING_KEY="xxx"

# ===========================================
# NextAuth.js
# ===========================================
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# OAuth Providers (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_ID=""
GITHUB_SECRET=""

# ===========================================
# Stripe
# ===========================================
# Get these from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_xxx"
STRIPE_PUBLISHABLE_KEY="pk_test_xxx"
STRIPE_WEBHOOK_SECRET="whsec_xxx"

# ===========================================
# PayPal
# ===========================================
# Get these from: https://developer.paypal.com
PAYPAL_CLIENT_ID="xxx"
PAYPAL_CLIENT_SECRET="xxx"
PAYPAL_WEBHOOK_ID="xxx"

# ===========================================
# Coinbase Commerce
# ===========================================
# Get these from: https://commerce.coinbase.com/dashboard/settings
COINBASE_COMMERCE_API_KEY="xxx"
COINBASE_COMMERCE_WEBHOOK_SECRET="xxx"

# ===========================================
# Admin Configuration
# ===========================================
# API key for admin endpoints (required for /api/admin/* routes)
ADMIN_KEY="generate-a-secure-random-string"

# Comma-separated list of admin user IDs (from database)
ADMIN_USER_IDS=""

# Comma-separated list of admin email addresses
ADMIN_EMAILS=""

# ===========================================
# Storage (for snapshots and recordings)
# ===========================================
# Cloud storage URL for media files
STORAGE_URL=""

# S3-compatible storage credentials (optional)
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# AWS_S3_BUCKET=""
# AWS_S3_REGION=""

# ===========================================
# Logging
# ===========================================
# Log level: debug, info, warn, error (default: info in prod, debug in dev)
LOG_LEVEL="info"

# ===========================================
# Feature Flags (optional)
# ===========================================
# Enable live hardware mode (requires Raspberry Pi)
# ENABLE_LIVE_MODE="true"

# Enable tournament system
# ENABLE_TOURNAMENTS="true"
